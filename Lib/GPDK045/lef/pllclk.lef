### For black box
MACRO pllclk
  CLASS BLOCK ;
  ORIGIN 0.06 0 ;
  SIZE 75.03 BY 136.795 ;
  SYMMETRY X Y R90 ;

  PIN refclk
  DIRECTION INPUT ;
    AntennaGateArea  0.039 ;
     PORT
      LAYER Metal1 ;
        RECT 0 80.115 0.15 80.305 ;
     END
  END refclk

  PIN clk1x
  DIRECTION OUTPUT ;
    ANTENNADIFFAREA 1.7285  LAYER Metal1 ;
     PORT
      LAYER Metal2 ;
        RECT 31.86 113.04 32.16 113.34 ;
     END
  END clk1x

  PIN clk2x
  DIRECTION OUTPUT ;
    ANTENNADIFFAREA 1.7285  LAYER Metal1 ;
     PORT
      LAYER Metal2 ;
        RECT 31.86 122.28 32.16 122.58 ;
     END
  END clk2x

  PIN ibias
  DIRECTION INPUT ;
    AntennaGateArea  0.039 ;
     PORT
      LAYER Metal2 ;
        RECT 0 89.95 0.3 90.25 ;
     END
  END ibias

