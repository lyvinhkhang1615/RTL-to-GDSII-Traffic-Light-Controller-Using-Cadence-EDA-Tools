  PIN agnd!
  DIRECTION INOUT ;
  USE GROUND ;
     PORT
      LAYER Metal3 ;
        RECT 0 2.39 66.14 4.89 ;
        RECT 0 2.385 0.3 4.89 ;
     END
     PORT
      LAYER Metal3 ;
        RECT 0 84.23 66.14 86.73 ;
        RECT 0 84.225 0.3 86.73 ;
     END
  END agnd!

  PIN avdd!
  DIRECTION INOUT ;
  USE POWER ;
     PORT
      LAYER Metal3 ;
        RECT 0 5.685 0.3 8.19 ;
        RECT 0 5.69 66.14 8.19 ;
     END
     PORT
      LAYER Metal3 ;
        RECT 0 80.925 0.295 83.43 ;
        RECT -0.005 80.93 66.14 83.425 ;
        RECT -0.005 80.925 0.295 83.425 ;
        RECT 0 80.93 66.14 83.43 ;
     END
  END avdd!
  OBS
