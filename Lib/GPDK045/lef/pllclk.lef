        RECT 0.07 0.07 34.25 103.06 ;
      LAYER Metal2 ;
        RECT 0.07 0.07 74.93 86.66 ;
        RECT 5.315 0.07 34.25 108.445 ;
        RECT 5.315 0.07 32.09 136.725 ;
        RECT 0.07 0.07 34.25 103.06 ;
      LAYER Metal3 ;
        RECT 0.07 0.07 54.93 86.66 ;
        RECT 5.315 0.07 34.25 108.445 ;
        RECT 5.315 0.07 32.09 136.725 ;
        RECT 0.07 0.07 34.25 103.06 ;
      LAYER Metal4 ;
        RECT 0.07 0.07 74.93 86.66 ;
        RECT 5.315 0.07 34.25 108.445 ;
        RECT 5.315 0.07 32.09 136.725 ;
        RECT 0.07 0.07 34.25 103.06 ;
